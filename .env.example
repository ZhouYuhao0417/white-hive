WHITEHIVE_ALLOW_PROVIDER_BRIDGE=0
WHITEHIVE_ALLOW_DEMO_SESSION=0
RESEND_API_KEY=
EMAIL_FROM=WhiteHive <no-reply@whitehive.cn>
WHITEHIVE_EMAIL_MOCK=0

# SMS verification (Spug is recommended for the current personal-developer setup)
WHITEHIVE_SMS_PROVIDER=spug
SPUG_SMS_URL=
SPUG_SMS_APP_NAME=WhiteHive
